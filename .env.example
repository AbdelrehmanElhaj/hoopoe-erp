# Copy to .env and fill in values
DB_URL=jdbc:postgresql://localhost:5432/accounting_db
DB_USER=accounting_user
DB_PASSWORD=change_me

# Generate with: openssl rand -base64 64
JWT_SECRET=change-this-in-production-must-be-256-bits-long

# Generate with: openssl rand -base64 32
PRIVATE_KEY_ENCRYPTION_KEY=change-this-32-char-key

ZATCA_ENV=sandbox
